  "item": [
    {
      "name": "1: Schema & Constraint Validation",
      "item": [
        {
          "name": "Test Case 1.1: Negative Price Validation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 400\", function () {\r",
                  "    pm.response.to.have.status(400);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Check Constraint Triggered\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    // MySQL Error 3819 is for Check Constraint violation\r",
                  "    pm.expect(jsonData.error_code).to.equal(3819);\r",
                  "    pm.expect(jsonData.message).to.include(\"Check constraint 'products_chk_1' is violated\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"query\": \"INSERT INTO products (name, price, stock) VALUES ('Broken Item', -10.00, 5);\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/execute",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "execute"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Test Case 1.2: Mandatory Field (NOT NULL) Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Fails when mandatory 'name' is missing\", function () {\r",
                  "    pm.response.to.have.status(400);\r",
                  "    pm.expect(pm.response.json().message).to.include(\"doesn't have a default value\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"query\": \"INSERT INTO products (price, stock) VALUES (10.00, 5);\" \r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/execute",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "execute"
              ]
            },
            "description": "Mandatory Field name' is missing"
          },
          "response": []
        },
        {
          "name": "Test Case 1.3: Duplicate Entry Prevention",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 400 for Duplicate\", function () {\r",
                  "    pm.response.to.have.status(400);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Verify MySQL Duplicate Error Code\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    // MySQL Error 1062 is for Duplicate Entry\r",
                  "    pm.expect(jsonData.error_code).to.equal(1062);\r",
                  "    pm.expect(jsonData.message).to.include(\"Duplicate entry\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"query\": \"INSERT INTO products (name, price, stock) VALUES ('Test Laptop', 500, 1);\" \r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/execute",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "execute"
              ]
            },
            "description": "Mandatory Field name' is missing"
          },
          "response": []
